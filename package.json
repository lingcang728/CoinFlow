{
  "name": "coinflow",
  "version": "1.0.3",
  "description": "Electron-first 桌面端本地记账应用",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "electron .",
    "desktop": "electron .",
    "start": "electron .",
    "build:desktop": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& electron-builder --win portable",
    "postbuild:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-release-artifacts.ps1 && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-desktop-shortcut.ps1",
    "shortcut:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-desktop-shortcut.ps1",
    "smoke:desktop": "set COINFLOW_SMOKE_TEST=1&& electron .",
    "install:electron": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& node node_modules/electron/install.js",
    "postinstall": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& node node_modules/electron/install.js"
  },
  "keywords": [
    "desktop",
    "electron",
    "accounting",
    "大学生记账"
  ],
  "author": "凌苍",
  "license": "ISC",
  "build": {
    "appId": "com.lingcang.coinflow",
    "productName": "CoinFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "assets/**/*",
      "css/**/*",
      "desktop/**/*",
      "js/**/*",
      "vendor/**/*",
      "favicon.png",
      "index.html",
      "package.json"
    ],
    "win": {
      "icon": "assets/icons/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "CoinFlow-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  }
}
