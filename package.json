{
  "name": "coinflow",
  "version": "1.1.5",
  "description": "Electron-first 桌面端本地记账应用",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "electron .",
    "desktop": "electron .",
    "start": "electron .",
    "build:desktop": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& electron-builder --win nsis",
    "postbuild:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-release-artifacts.ps1 && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-desktop-shortcut.ps1",
    "shortcut:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-desktop-shortcut.ps1",
    "smoke:desktop": "set COINFLOW_SMOKE_TEST=1&& electron .",
    "install:electron": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& node node_modules/electron/install.js",
    "postinstall": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& node node_modules/electron/install.js"
  },
  "keywords": [
    "desktop",
    "electron",
    "accounting",
    "大学生记账"
  ],
  "author": "凌苍",
  "license": "ISC",
  "build": {
    "appId": "com.lingcang.coinflow",
    "productName": "CoinFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "assets/**/*",
      "css/**/*",
      "desktop/**/*",
      "js/**/*",
      "vendor/**/*",
      "favicon.png",
      "index.html",
      "package.json"
    ],
    "win": {
      "icon": "assets/icons/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "CoinFlow-Setup-${version}.exe",
      "shortcutName": "CoinFlow"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://coinflow-1408718786.cos.ap-shanghai.myqcloud.com/",
        "channel": "latest"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  }
}
